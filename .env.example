ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
ELEVENLABS_API_KEY=...

# Models. Default to Opus 4.7 for quality; switch to claude-sonnet-4-6 to hit the ~€1/doc budget.
EDITOR_MODEL=claude-sonnet-4-6
JUDGE_MODEL=claude-sonnet-4-6

# STT backend. Use ElevenLabs Scribe by default. Set STT_MODEL=scribe_v1 if you need v1.
STT_BACKEND=elevenlabs
STT_MODEL=scribe_v2
STT_LANGUAGE_CODE=
STT_DIARIZE=true
STT_TAG_AUDIO_EVENTS=true
STT_NO_VERBATIM=false
