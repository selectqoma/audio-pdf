ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Models. Default to Opus 4.7 for quality; switch to claude-sonnet-4-6 to hit the ~€1/doc budget.
EDITOR_MODEL=claude-sonnet-4-6
JUDGE_MODEL=claude-sonnet-4-6

# STT backend. Currently only "openai" is implemented. Swap to local faster-whisper later if desired.
STT_BACKEND=openai
STT_MODEL=whisper-1
